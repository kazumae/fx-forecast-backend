# Application
PROJECT_NAME="FX Forecast API"
VERSION="1.0.0"
API_V1_STR="/api/v1"

# Database
DATABASE_URL=postgresql://fx_user:fx_password@localhost:6543/fx_forecast

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# # Security
# SECRET_KEY=your-secret-key-here
# ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=30

# # External APIs
# FOREX_API_KEY=
# FOREX_API_URL=https://api.example.com/forex

# TraderMade API Configuration
# Get your API key from https://tradermade.com
# Free tier: 1000 requests/month
TRADERMADE_API_KEY=
# Live Streaming Plan Configuration
TRADERMADE_STREAMING_API_KEY=
TRADERMADE_WEBSOCKET_URL=wss://marketdata.tradermade.com/feedadv
TARGET_SYMBOL=XAUUSD

# Streaming Configuration
RECONNECT_INTERVAL=1
MAX_RECONNECT_INTERVAL=60
HEARTBEAT_INTERVAL=30

# Slack Configuration
SLACK_WEBHOOK_URL=
SLACK_DEFAULT_CHANNEL=#general
SLACK_BOT_TOKEN=

# Slack Error Notifications
SLACK_ERROR_NOTIFICATION_ENABLED=true
SLACK_ERROR_NOTIFICATION_COOLDOWN=300